# MQTT配置
MQTT_BROKER_URL=tcp://183.6.33.81:1883
MQTT_USERNAME=zfiUser
MQTT_PASSWORD=zfiUser@123
MQTT_CLIENT_ID=NEST20202412U002

# 订阅主题（多个主题用逗号分隔）
# 使用通配符 + 订阅所有设备
MQTT_TOPICS=thing/product/+/osd,thing/product/+/events

# 服务器配置
PORT=3001
WS_PORT=3002

# ========== 阈值配置 ==========
# 格式: 最小值,最大值 (用逗号分隔)
# 多区间格式: 用分号分隔多个区间，如 0,20;30,70
# 状态判断: 值在normal区间内为正常, warning区间内为警告, critical区间内为严重

# 风速阈值 (m/s)
WIND_SPEED_NORMAL=0,6.6
WIND_SPEED_WARNING=6.6,12
WIND_SPEED_CRITICAL=12,999

# 湿度阈值 (%) - 多区间示例
# 正常: 0-20% 或 30-70%
# 警告: 20-30% 或 70-80%
# 严重: 80-100%
HUMIDITY_NORMAL=0,20;30,70
HUMIDITY_WARNING=20,30;70,80
HUMIDITY_CRITICAL=80,100

# ========== 设备配置 ==========
# 格式: 设备ID=设备名称 (每行一个)
# 用于在界面上显示友好的设备名称

DEVICE_8UUXP3B00A10VD=南洲-Dock3-M4TD
